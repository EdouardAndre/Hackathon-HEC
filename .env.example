# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# ── Swan Sandbox credentials ──────────────────────────────────────────────────
# Get these from https://dashboard.swan.io → Settings → OAuth clients
SWAN_CLIENT_ID="SANDBOX_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
SWAN_CLIENT_SECRET="your_client_secret"
SWAN_PROJECT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# OAuth redirect — must be registered in Swan Dashboard → OAuth clients → Redirect URIs
SWAN_REDIRECT_URI="http://localhost:8501/callback"

# User access token — obtain via the OAuth flow
SWAN_USER_ACCESS_TOKEN="your_user_access_token"

# Account details — available in Swan Dashboard after onboarding
SWAN_ACCOUNT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
SWAN_ACCOUNT_HOLDER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
SWAN_ACCOUNT_IBAN="FR76 9999 9001 xxxx xxxx xxxx xxx"
SWAN_ACCOUNT_MEMBERSHIP_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
